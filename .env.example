# Copy this file to .env and replace the placeholders with your own values.

# Groq API key for the triage and hospital-selection AI nodes.
GROQ_API_KEY=your_groq_api_key

# EmailJS configuration for appointment/triage email notifications.
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key

# Optional SMTP fallback (only needed if you want SMTP instead of EmailJS).
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SENDER_EMAIL=
